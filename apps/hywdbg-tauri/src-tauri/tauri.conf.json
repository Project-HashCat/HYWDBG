{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HYWDbg",
  "version": "0.1.0",
  "identifier": "moe.hywd.bg",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HYWDbg",
        "width": 1448,
        "height": 1000,
        "minWidth": 1100,
        "minHeight": 760
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}