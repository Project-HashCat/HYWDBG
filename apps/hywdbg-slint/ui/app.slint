import { LineEdit, ScrollView } from "std-widgets.slint";

global Theme {
    in property <color> bg0: #1e1e1e;
    in property <color> bg1: #232323;
    in property <color> bg2: #272727;
    in property <color> bg3: #303030;
    in property <color> header: #2b2b2b;
    in property <color> header2: #333333;
    in property <color> border: #555555;
    in property <color> border-soft: #3d3d3d;
    in property <color> text: #d8d8d8;
    in property <color> muted: #9b9b9b;
    in property <color> code: #d4d4d4;
    in property <color> addr: #77c36a;
    in property <color> bytes: #b7b7b7;
    in property <color> mnemonic: #78a8ff;
    in property <color> operand: #d9d9d9;
    in property <color> comment: #8bcf8b;
    in property <color> branch: #d7ba7d;
    in property <color> danger: #ff6a6a;
    in property <color> blue: #3978d8;
    in property <color> select: #214d86;
    in property <color> green: #54d16a;
    in property <color> red: #ff5b5b;
    in property <color> yellow: #d7ba7d;
    in property <color> purple: #c586c0;
}

component HitBox inherits TouchArea { }

component ToolbarButton inherits Rectangle {
    in property <string> text;
    in property <string> key;
    in property <color> accent: Theme.blue;
    callback clicked;

    height: 28px;
    min-width: 74px;
    border-radius: 3px;
    border-width: 1px;
    border-color: hit.has-hover ? root.accent : Theme.border-soft;
    background: hit.pressed ? #383838 : (hit.has-hover ? #30343b : Theme.bg2);

    hit := HitBox { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 7px;
        padding-right: 7px;
        spacing: 5px;
        Text {
            text: root.key;
            color: root.accent;
            font-size: 12px;
            font-weight: 800;
            vertical-alignment: center;
        }
        Text {
            text: root.text;
            color: Theme.text;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
}

component MiniButton inherits Rectangle {
    in property <string> text;
    callback clicked;
    height: 26px;
    min-width: 62px;
    border-radius: 3px;
    border-width: 1px;
    border-color: hit.has-hover ? Theme.blue : Theme.border-soft;
    background: hit.pressed ? #383838 : (hit.has-hover ? #30343b : Theme.bg2);
    hit := HitBox { clicked => { root.clicked(); } }
    Text {
        text: root.text;
        color: Theme.text;
        font-size: 11px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component PanelHeader inherits Rectangle {
    in property <string> title;
    in property <bool> active: false;
    height: 25px;
    background: root.active ? #253957 : Theme.header;
    Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border-soft; }
    HorizontalLayout {
        padding-left: 7px;
        padding-right: 6px;
        Text { text: root.title; color: #ededed; font-size: 12px; font-weight: 700; vertical-alignment: center; }
        Text { text: ""; horizontal-stretch: 1; }
        Text { text: "..."; color: Theme.muted; font-size: 11px; vertical-alignment: center; }
    }
}

component PlainPanel inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <bool> active: false;
    in property <color> body-color: Theme.code;

    border-width: 1px;
    border-color: root.active ? Theme.blue : Theme.border-soft;
    border-radius: 3px;
    background: Theme.bg1;
    clip: true;

    VerticalLayout {
        spacing: 0px;
        PanelHeader { title: root.title; active: root.active; }
        ScrollView {
            Text {
                x: 7px;
                y: 5px;
                text: root.body;
                color: root.body-color;
                font-size: 11px;
            }
        }
    }
}

component DisasmPanel inherits Rectangle {
    in property <string> pc-text;
    in property <string> addr-text;
    in property <string> bytes-text;
    in property <string> mnemonic-text;
    in property <string> operand-text;
    in property <string> comment-text;

    border-width: 1px;
    border-color: Theme.blue;
    border-radius: 3px;
    background: Theme.bg1;
    clip: true;

    VerticalLayout {
        spacing: 0px;
        PanelHeader { title: "CPU / Disassembly"; active: true; }
        Rectangle {
            height: 24px;
            background: #202020;
            HorizontalLayout {
                padding-left: 7px;
                Text { text: "RIP"; color: Theme.green; font-size: 11px; font-weight: 700; vertical-alignment: center; }
                Text { text: "  " + root.pc-text; color: Theme.text; font-size: 11px; vertical-alignment: center; }
            }
        }
        Rectangle {
            height: 22px;
            background: #262626;
            HorizontalLayout {
                padding-left: 22px;
                spacing: 0px;
                Text { width: 150px; text: "Address"; color: #bfbfbf; font-size: 11px; vertical-alignment: center; }
                Text { width: 255px; text: "Bytes"; color: #bfbfbf; font-size: 11px; vertical-alignment: center; }
                Text { width: 92px; text: "Mnemonic"; color: #bfbfbf; font-size: 11px; vertical-alignment: center; }
                Text { horizontal-stretch: 1; text: "Operands"; color: #bfbfbf; font-size: 11px; vertical-alignment: center; }
                Text { width: 260px; text: "Comment"; color: #bfbfbf; font-size: 11px; vertical-alignment: center; }
            }
        }
        ScrollView {
            Rectangle {
                height: 1200px;
                background: Theme.bg1;
                HorizontalLayout {
                    x: 5px;
                    y: 4px;
                    spacing: 0px;
                    Text { width: 17px; text: "->"; color: Theme.green; font-size: 11px; }
                    Text { width: 150px; text: root.addr-text; color: Theme.addr; font-size: 11px; }
                    Text { width: 255px; text: root.bytes-text; color: Theme.bytes; font-size: 11px; }
                    Text { width: 92px; text: root.mnemonic-text; color: Theme.mnemonic; font-size: 11px; font-weight: 700; }
                    Text { horizontal-stretch: 1; text: root.operand-text; color: Theme.operand; font-size: 11px; }
                    Text { width: 260px; text: root.comment-text; color: Theme.comment; font-size: 11px; }
                }
            }
        }
    }
}

component RegisterPanel inherits Rectangle {
    in property <string> regs;
    in property <string> flags;

    border-width: 1px;
    border-color: Theme.border-soft;
    border-radius: 3px;
    background: Theme.bg1;
    clip: true;

    VerticalLayout {
        spacing: 0px;
        PanelHeader { title: "Registers"; }
        Rectangle {
            height: 24px;
            background: #202020;
            Text { x: 8px; text: "General (x64)"; color: Theme.text; font-size: 11px; vertical-alignment: center; }
        }
        ScrollView {
            vertical-stretch: 1;
            Text { x: 8px; y: 6px; text: root.regs; color: #ff8080; font-size: 11px; }
        }
        Rectangle { height: 1px; background: Theme.border-soft; }
        Rectangle {
            height: 78px;
            background: #202020;
            Text { x: 8px; y: 6px; text: root.flags; color: Theme.code; font-size: 11px; }
        }
    }
}

export component MainWindow inherits Window {
    title: "HYWDbg - Native Slint Debugger";
    width: 1500px;
    height: 920px;
    background: Theme.bg0;

    in-out property <string> status-text: "Idle";
    in-out property <string> core-state: "offline";
    in-out property <string> backend-state: "none";
    in-out property <string> pid-text: "----";
    in-out property <string> tid-text: "----";
    in-out property <string> arch-text: "x64";
    in-out property <string> target-text: "no target";

    in-out property <string> processes-text: "Core offline";
    in-out property <string> modules-text: "No target";
    in-out property <string> threads-text: "No target";
    in-out property <string> breakpoints-text: "No breakpoints";
    in-out property <string> memory-map-text: "No target";

    in-out property <string> pc-text: "00000000`00000000";
    in-out property <string> disasm-addr-text: "";
    in-out property <string> disasm-bytes-text: "";
    in-out property <string> disasm-mnemonic-text: "";
    in-out property <string> disasm-operand-text: "";
    in-out property <string> disasm-comment-text: "";

    in-out property <string> regs-text: "RAX  0000000000000000\nRBX  0000000000000000\nRCX  0000000000000000\nRDX  0000000000000000\nRSP  0000000000000000\nRIP  0000000000000000";
    in-out property <string> flags-text: "RFLAGS 00000000\nCF 0 PF 0 ZF 0 SF 0";
    in-out property <string> stack-text: "No stack";
    in-out property <string> hex-text: "No memory";
    in-out property <string> log-text: "[ready] HYWDbg Slint native frontend";
    in-out property <string> command-text: "";

    callback core-clicked();
    callback winapi-clicked();
    callback stop-clicked();
    callback open-exe-clicked();
    callback attach-clicked();
    callback run-clicked();
    callback pause-clicked();
    callback step-clicked();
    callback bp-clicked();
    callback command-clicked(string);

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: 30px;
            background: #232323;
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 16px;
                Text { text: "?  HYWDbg"; color: #f0f0f0; font-size: 14px; font-weight: 800; vertical-alignment: center; }
                Text { text: "File"; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: "View"; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: "Debug"; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: "Plugins"; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: "Window"; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: "Help"; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: ""; horizontal-stretch: 1; }
                Text { text: root.target-text; color: Theme.muted; font-size: 11px; vertical-alignment: center; }
                Text { text: root.core-state; color: root.core-state == "online" ? Theme.green : Theme.red; font-size: 11px; vertical-alignment: center; }
            }
        }

        Rectangle {
            height: 46px;
            background: #262626;
            Rectangle { y: parent.height - 1px; width: 100%; height: 1px; background: Theme.border-soft; }
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 6px;
                ToolbarButton { text: "Run F5"; key: "RUN"; accent: Theme.green; clicked => { root.run-clicked(); } }
                ToolbarButton { text: "Pause F6"; key: "PAU"; accent: Theme.blue; clicked => { root.pause-clicked(); } }
                ToolbarButton { text: "Step F11"; key: "STP"; accent: Theme.blue; clicked => { root.step-clicked(); } }
                ToolbarButton { text: "Breakpoint"; key: "BP"; accent: Theme.red; clicked => { root.bp-clicked(); } }
                ToolbarButton { text: "Open EXE"; key: "OPN"; accent: Theme.yellow; clicked => { root.open-exe-clicked(); } }
                ToolbarButton { text: "Attach"; key: "ATT"; accent: Theme.purple; clicked => { root.attach-clicked(); } }
                Text { text: ""; horizontal-stretch: 1; }
                MiniButton { text: "Core"; clicked => { root.core-clicked(); } }
                MiniButton { text: "WinAPI"; clicked => { root.winapi-clicked(); } }
                MiniButton { text: "Stop"; clicked => { root.stop-clicked(); } }
            }
        }

        HorizontalLayout {
            spacing: 4px;
            padding: 4px;
            vertical-stretch: 1;

            VerticalLayout {
                width: 320px;
                spacing: 4px;
                PlainPanel { height: 128px; title: "Processes"; body: root.processes-text; active: true; }
                PlainPanel { height: 144px; title: "Modules"; body: root.modules-text; }
                PlainPanel { height: 116px; title: "Threads"; body: root.threads-text; }
                PlainPanel { height: 96px; title: "Breakpoints"; body: root.breakpoints-text; }
                PlainPanel { title: "Memory Map"; body: root.memory-map-text; }
            }

            VerticalLayout {
                spacing: 4px;
                horizontal-stretch: 1;
                DisasmPanel {
                    vertical-stretch: 1;
                    pc-text: root.pc-text;
                    addr-text: root.disasm-addr-text;
                    bytes-text: root.disasm-bytes-text;
                    mnemonic-text: root.disasm-mnemonic-text;
                    operand-text: root.disasm-operand-text;
                    comment-text: root.disasm-comment-text;
                }
                HorizontalLayout {
                    height: 176px;
                    spacing: 4px;
                    PlainPanel { title: "Stack"; body: root.stack-text; }
                    PlainPanel { title: "Hex View"; body: root.hex-text; }
                }
                Rectangle {
                    height: 132px;
                    border-width: 1px;
                    border-color: Theme.border-soft;
                    border-radius: 3px;
                    background: Theme.bg1;
                    clip: true;
                    VerticalLayout {
                        spacing: 0px;
                        PanelHeader { title: "Log / Console"; }
                        ScrollView {
                            height: 68px;
                            Text { x: 8px; y: 5px; text: root.log-text; color: Theme.code; font-size: 11px; }
                        }
                        Rectangle {
                            height: 34px;
                            background: #202020;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;
                                Text { text: "hyw>"; color: Theme.blue; font-size: 12px; vertical-alignment: center; }
                                LineEdit {
                                    text <=> root.command-text;
                                    placeholder-text: "help | launch <exe> | attach <pid> | r | u | db | bp | g | t";
                                }
                                MiniButton { text: "Enter"; clicked => { root.command-clicked(root.command-text); root.command-text = ""; } }
                            }
                        }
                    }
                }
            }

            RegisterPanel {
                width: 300px;
                regs: root.regs-text;
                flags: root.flags-text;
            }
        }

        Rectangle {
            height: 23px;
            background: #242424;
            Rectangle { width: 100%; height: 1px; background: Theme.border-soft; }
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 18px;
                Text { text: "Status: " + root.status-text; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: "PID: " + root.pid-text; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: "TID: " + root.tid-text; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: "Arch: " + root.arch-text; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: "Backend: " + root.backend-state; color: Theme.text; font-size: 11px; vertical-alignment: center; }
                Text { text: ""; horizontal-stretch: 1; }
                Text { text: "Slint native / no WebView"; color: Theme.muted; font-size: 11px; vertical-alignment: center; }
            }
        }
    }
}
